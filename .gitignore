# ── Runtime data (PDFs, extracted text, embeddings) ──────────────────────────
# IMPORTANT: Never commit data/ — it contains copies of ingested PDFs (copyright)
# and potentially sensitive research content.
data/
input/

# ── Local Claude Code settings ────────────────────────────────────────────────
# settings.json may contain absolute paths; keep it out of version control.
.claude/settings.json
.claude/settings.local.json
# .mcp.json contains machine-specific absolute paths — never commit.
.mcp.json

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/

# ── Environment / secrets ─────────────────────────────────────────────────────
# All .env files are ignored. Only .env.example (no real keys) is versioned.
.env
.env.*
!.env.example

# ── Test / coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
